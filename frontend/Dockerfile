FROM node:20-alpine

# Встановлюємо робочу директорію всередині контейнера
WORKDIR /app

# Копіюємо файли залежностей
COPY package*.json ./

# Встановлюємо залежності
RUN npm install

# Копіюємо решту файлів
COPY . .

# Відкриваємо порт для зовнішнього доступу (Vite)
EXPOSE 5173

# Запускаємо локальний dev-сервер (прокидаючи host, щоб Docker міг слухати локальні запити)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
